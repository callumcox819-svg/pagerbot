# Telegram bot (BotFather)
BOT_TOKEN=

# Fernet key for encrypting Pager passwords/sessions in DB.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Optional: OpenAI for ambiguous client replies (rule-based works without it)
OPENAI_API_KEY=

# Optional: admin Telegram user IDs (comma-separated)
ADMIN_IDS=

# Worker poll interval (seconds)
PAGER_POLL_SEC=45

# SQLite path (default) or leave empty
# DATABASE_PATH=data/bot.db
